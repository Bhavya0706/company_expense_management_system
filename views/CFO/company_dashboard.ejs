<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Company Analytics Dashboard</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="/css/manager.css">

<style>

.analytics-page{
    padding: 30px;
    max-width: 1400px;
    margin: auto;
}

/* HEADER */

.analytics-header{
    margin-bottom: 30px;
}

.analytics-header h1{
    font-size: 32px;
    color: #17384a;
    margin-bottom: 8px;
}

.analytics-header p{
    color: #6b8fa0;
    font-size: 15px;
}

/* TOP STATS */

.top-stats{
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(230px,1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.big-stat{
    background: white;
    border-radius: 20px;
    padding: 25px;
    box-shadow: 0 4px 18px rgba(48,185,227,0.08);
    border-left: 5px solid #30b9e3;
}

.big-stat.green{
    border-left-color: #27ae60;
}

.big-stat.red{
    border-left-color: #e74c3c;
}

.big-stat.orange{
    border-left-color: #f39c12;
}

.big-stat h3{
    font-size: 13px;
    color: #6b8fa0;
    text-transform: uppercase;
    margin-bottom: 12px;
}

.big-stat h1{
    font-size: 32px;
    color: #17384a;
}

/* CHARTS */

.chart-grid{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 30px;
}

@media(max-width:900px){
    .chart-grid{
        grid-template-columns: 1fr;
    }
}

.chart-card{
    background: white;
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 4px 18px rgba(48,185,227,0.08);
}

.chart-card h2{
    font-size: 18px;
    color: #17384a;
    margin-bottom: 20px;
}

.chart-wrap{
    position: relative;
    height: 320px;
}

/* TABLES */ */

 .table-grid{
    display: grid;
    grid-template-columns: 1fr ;
    gap: 24px;
}

@media(max-width:1000px){
    .table-grid{
        grid-template-columns: 1fr;
    }
}

.table-card{
    background: white;
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 4px 18px rgba(48,185,227,0.08);
}

.table-card h2{
    font-size: 18px;
    color: #17384a;
    margin-bottom: 18px;
}

.analytics-table{
    width: 100%;
    border-collapse: collapse;
}

.analytics-table thead{
    background: #f4fbfe;
}

.analytics-table th{
    padding: 14px;
    text-align: left;
    color: #6b8fa0;
    font-size: 13px;
}

.analytics-table td{
    padding: 16px 14px;
    border-bottom: 1px solid #edf4f7;
    font-size: 14px;
}

.analytics-table tr:hover{
    background: #f9fcfd;
}

.amount{
    font-weight: 700;
    color: #17384a;
}

/* STATUS */

.status{
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
}

.status.approved{
    background: #eafaf1;
    color: #27ae60;
}

.status.pending{
    background: #fff6dd;
    color: #f39c12;
}

.status.rejected{
    background: #fdecec;
    color: #e74c3c;
}

</style>
</head>

<body>

<%- include('../partials/CFO_nav') %>

<div class="analytics-page">

    <!-- HEADER -->

    <div class="analytics-header">
        <h1>Company Analytics Dashboard</h1>
        <p>Overall insights of employees, managers and expenses</p>
    </div>

    <!-- TOP STATS -->

    <div class="top-stats">

        <div class="big-stat">
            <h3>Total Company Expense</h3>
            <h1 id="total"></h1>
        </div>

        <div class="big-stat green">
            <h3>Approved Expense</h3>
            <h1 id="approved">₹8.4L</h1>
        </div>

        <div class="big-stat orange">
            <h3>Pending Expense</h3>
            <h1 id="pending">₹2.1L</h1>
        </div>

        <div class="big-stat red">
            <h3>Rejected Expense</h3>
            <h1 id="rejected">₹2.3L</h1>
        </div>

    </div>

    <!-- CHARTS -->

    <div class="chart-grid">

        
        
                <!-- BAR CHART -->
        
                <div class="chart-card">
                    <h2>Monthly Expense Trend</h2>
        
                    <div class="chart-wrap">
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>

                    <!-- CATEGORY CHART -->

    <div class="chart-card">

            <h2>Expense Categories</h2>
        <div class="chart-wrap">
            <canvas id="categoryChart" style="justify-self: center;"></canvas>
        </div>

    </div>


        <!-- PIE CHART -->

        <div class="chart-card">
            <h2>Expense Status Distribution</h2>

            <div class="chart-wrap" >
                <canvas id="statusChart" style="justify-self: center;"></canvas>
            </div>    
        </div>            

         <!-- LINE CHART -->
        
         <div class="chart-card">
            <h2>Monthly Requets Trend</h2>

            <div class="chart-wrap">
                <canvas id="requestTrendChart"></canvas>
            </div>
        </div>
    </div>
         <!-- LINE CHART -->
        
         <div class="chart-card">
            <h2 style="text-align: center;">Daily Request Trend</h2>

            <div class="chart-wrap">
                <canvas id="dailyRequestChart" style="justify-self: center;"></canvas>
            </div>
        </div>
    </div>
    <!-- TABLES -->

    <div class="table-grid">



             <!-- TOP manager -->

             <div class="table-card">

                <h2>Top managers</h2>
    
                <table class="analytics-table">
    
                    <thead>
                        <tr>
                            <th>manager</th>
                            <th> manager's finance manager</th>
                            <th>Total approved Requests</th>
                            <th>Approved Expense</th>
                        </tr>
                    </thead>
    
                    <tbody id="topmanagerbody">
    
                        
              
                    </tbody>
    
                </table>
    
            </div>
    
    
        </div>

        <!-- TOP EMPLOYEES -->

        <div class="table-card">

            <h2>Top Employees</h2>

            <table class="analytics-table">

                <thead>
                    <tr>
                        <th>Employe</th>
                        <th>employe's manager</th>
                        <th>Total approved Requests</th>
                        <th>Approved Expense</th>
                    </tr>
                </thead>

                <tbody id="topEmployeeBody">

                    
          
                </tbody>

            </table>

        </div>


    </div>


    
<script>   const allexpenses = <%- JSON.stringify(allexpenses) %> </script>
<script src="/js/company_dashboard_for_CFO.js"></script>
</body>

</html>